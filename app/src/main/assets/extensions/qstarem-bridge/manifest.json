{
  "manifest_version": 2,
  "name": "QStarem Bridge",
  "version": "1.0.11",
  "description": "Native bridge for QStarem playback and shell integration",
  "web_accessible_resources": [
    "icons/icon-1.png",
    "icons/icon-2.png",
    "icons/icon-3.png",
    "icons/icon-4.png",
    "icons/icon-5.png",
    "icons/icon-6.png"
  ],
  "applications": {
    "gecko": {
      "id": "qstarem-bridge@qstarem.app",
      "strict_min_version": "68.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["shell.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
